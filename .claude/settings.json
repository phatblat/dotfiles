{
  "agentPushNotifEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "csharp-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "linear-cli@linear-cli": true,
    "lua-lsp@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "env": {
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_MCP_OUTPUT_TOKENS": "25000"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "repo": "EveryInc/compound-engineering-plugin",
        "source": "github"
      }
    },
    "linear-cli": {
      "source": {
        "repo": "schpet/linear-cli",
        "source": "github"
      }
    },
    "obsidian-skills": {
      "autoUpdate": true,
      "source": {
        "repo": "kepano/obsidian-skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/auto-format.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "command -v code-review-graph >/dev/null && code-review-graph update --skip-flows || true",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/posttooluse-failure.sh",
            "timeout": 3,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/pre-compact.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/write-guard.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/bash-guard.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/main-branch-guard.sh",
            "timeout": 2,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/pre-commit-format.sh",
            "if": "Bash(git commit*)",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/session-end.sh",
            "timeout": 3,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/session-start.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "command -v code-review-graph >/dev/null && code-review-graph status || true",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "node ~/.claude/agent-flow/hook.js",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/user-prompt-secrets.sh",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "mcp__acp__Edit",
      "mcp__acp__Bash",
      "mcp__acp__Write",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.basedpyright.com)",
      "Bash(claude mcp list)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git rev-list *)",
      "Bash(git ls-remote *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git symbolic-ref *)",
      "Bash(git merge --ff-only *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(gh pr list *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh api *)",
      "Bash(gh search *)",
      "Bash(sg *)",
      "Bash(just *)",
      "Bash(mise ls *)",
      "Bash(mise search *)",
      "Bash(rtk gain *)",
      "Bash(rtk discover)",
      "Bash(rtk --version)",
      "Bash(date *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(python3 *)",
      "Bash(jq *)"
    ],
    "deny": []
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "light"
}
