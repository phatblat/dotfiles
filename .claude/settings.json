{
  "agentPushNotifEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "compound-engineering@compound-engineering-plugin": true,
    "csharp-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "linear-cli@linear-cli": true,
    "lua-lsp@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "MAX_MCP_OUTPUT_TOKENS": "25000"
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "repo": "warpdotdev/claude-code-warp",
        "source": "github"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "repo": "EveryInc/compound-engineering-plugin",
        "source": "github"
      }
    },
    "linear-cli": {
      "source": {
        "repo": "schpet/linear-cli",
        "source": "github"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/auto-format.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash -c 'command -v code-review-graph >/dev/null 2>&1 && code-review-graph update >/dev/null 2>&1 &'",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/posttooluse-failure.sh",
            "timeout": 3,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/pre-compact.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/write-guard.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/bash-guard.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/pre-commit-format.sh",
            "if": "Bash(git commit*)",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/session-end.sh",
            "timeout": 3,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/session-start.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "command -v code-review-graph >/dev/null && root=$(git rev-parse --show-toplevel 2>/dev/null) && [ -e \"$root/.code-review-graph/graph.db\" ] && { code-review-graph update >/dev/null 2>&1; code-review-graph status; } || true",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/agent-flow/agent-flow-guard.sh",
            "timeout": 4,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/scripts/user-prompt-secrets.sh",
            "timeout": 2,
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "mcp__acp__Edit",
      "mcp__acp__Bash",
      "mcp__acp__Write",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.basedpyright.com)",
      "Bash(claude mcp list)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git rev-list *)",
      "Bash(git ls-remote *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git symbolic-ref *)",
      "Bash(git merge --ff-only *)",
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(git rebase *)",
      "Bash(git tag *)",
      "Bash(gh pr list *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr edit *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh search *)",
      "Bash(gh issue *)",
      "Bash(linear *)",
      "Bash(sg *)",
      "Bash(just *)",
      "Bash(mise ls *)",
      "Bash(mise search *)",
      "Bash(mise use *)",
      "Bash(mise install *)",
      "Bash(mise current *)",
      "Bash(mise self-update *)",
      "Bash(mise upgrade *)",
      "Bash(brew update*)",
      "Bash(brew outdated*)",
      "Bash(brew upgrade*)",
      "Bash(uv tool upgrade*)",
      "Bash(rtk *)",
      "Bash(code-review-graph *)",
      "Bash(ctx7 *)",
      "Bash(date *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(python3 *)",
      "Bash(jq *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(file *)",
      "Bash(stat *)"
    ],
    "defaultMode": "bypassPermissions",
    "deny": []
  },
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bun ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs",
    "type": "command"
  },
  "teammateMode": "in-process",
  "theme": "auto",
  "tui": "fullscreen",
  "worktree": {
    "baseRef": "fresh"
  }
}
