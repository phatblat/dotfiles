{
  "action": {
    "default_icon": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "description": "Live activity feed and @ref overlays for gstack browse",
  "host_permissions": [
    "http://127.0.0.1:*/",
    "ws://127.0.0.1:*/"
  ],
  "icons": {
    "128": "icons/icon-128.png",
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png"
  },
  "manifest_version": 3,
  "name": "gstack browse",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "version": "0.1.0"
}
