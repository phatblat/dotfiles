#!/usr/bin/env zsh

# members - List members of the given group
local group="$1"
if [[ -z "$group" ]]; then
    echo "Usage: members group"
    return 1
fi

# Using `while read` instead of `for` loop because shellcheck (SC2066) requires
# unquoted command substitution for word splitting, but shellharden re-adds quotes.
dscl . -list /Users | while read -r user; do
    if dsmemberutil checkmembership -U "$user" -G "$group" | grep -q "is a member"; then
        echo "$user"
    fi
done
