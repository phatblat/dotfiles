#!/usr/bin/env zsh

# rewrite - Rewrite commits changing author/committer email or name using git-filter-repo
if [[ $# -lt 3 || $# -gt 4 ]]; then
    echo "error: Usage: rewrite <email|name> old_value new_value [limit]" >&2
    return 1
fi

local field=$1
local old_value=$2
local new_value=$3
local limit=${4:-}

if [[ -n $limit && ! $limit =~ '^[0-9]+$' ]]; then
    echo "error: limit must be a positive integer, got: '$limit'" >&2
    return 1
fi

if ! command -v git-filter-repo &> /dev/null; then
    echo "error: git-filter-repo is not installed" >&2
    return 3
fi

local refs_arg=()
if [[ -n $limit ]]; then
    refs_arg=(--refs "HEAD~${limit}..HEAD")
fi

# https://htmlpreview.github.io/?https://github.com/newren/git-filter-repo/blob/docs/html/git-filter-repo.html#CALLBACKS
case $field in
email)
    git filter-repo --force \
        "${refs_arg[@]}" \
        --email-callback \
        "return email.replace(b\"$old_value\", b\"$new_value\")"
    ;;
name)
    git filter-repo --force \
        "${refs_arg[@]}" \
        --name-callback \
        "return name.replace(b\"$old_value\", b\"$new_value\")"
    ;;
*)
    echo "error: Unsupported field '$field'. Supported fields: email, name" >&2
    echo "error: Usage: rewrite <email|name> old_value new_value [limit]" >&2
    return 2
    ;;
esac
