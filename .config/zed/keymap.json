[
  {
    "bindings": {
      "cmd-l": "workspace::ToggleRightDock"
    }
  },
  {
    "bindings": {
      "cmd-1": "workspace::ToggleLeftDock"
    },
    "context": "Workspace"
  },
  {
    "bindings": {
      "cmd-2": "terminal_panel::Toggle"
    },
    "context": "Workspace"
  },
  {
    "bindings": {
      "ctrl-cmd-left": "pane::GoBack"
    },
    "context": "Pane"
  },
  {
    "bindings": {
      "ctrl-cmd-right": "pane::GoForward"
    },
    "context": "Pane"
  },
  {
    "bindings": {
      "cmd-'": [
        "editor::GoToPreviousDiagnostic",
        {
          "severity": {
            "max": "error",
            "min": "hint"
          }
        }
      ]
    },
    "context": "Editor"
  },
  {
    "bindings": {
      "alt-cmd-n": "workspace::NewWindow"
    },
    "context": "Workspace"
  }
]
