{
  "dividers": {
    "left": {
      "hard": "▌ ",
      "soft": "│ "
    },
    "right": {
      "hard": " ▐",
      "soft": " │"
    }
  },
  "segment_data": {
    "branch": {
      "before": "⎇ "
    },
    "cwd": {
      "args": {
        "ellipsis": "⋯"
      }
    },
    "line_current_symbol": {
      "contents": "␤ "
    },
    "player": {
      "args": {
        "state_symbols": {
          "fallback": "♫",
          "pause": "▮▮",
          "play": "▶",
          "stop": "■"
        }
      }
    },
    "powerline.segments.common.bat.battery": {
      "args": {
        "empty_heart": "♥",
        "full_heart": "♥",
        "offline": " ",
        "online": "⚡︎"
      }
    },
    "powerline.segments.common.env.virtualenv": {
      "before": "ⓔ  "
    },
    "powerline.segments.common.mail.email_imap_alert": {
      "before": "✉ "
    },
    "powerline.segments.common.net.hostname": {
      "before": "⌂ "
    },
    "powerline.segments.common.net.network_load": {
      "args": {
        "recv_format": "⬇ {value:>8}",
        "sent_format": "⬆ {value:>8}"
      }
    },
    "powerline.segments.common.sys.uptime": {
      "before": "⇑  "
    },
    "powerline.segments.common.time.fuzzy_time": {
      "args": {
        "unicode_text": true
      }
    },
    "powerline.segments.common.wthr.weather": {
      "args": {
        "icons": {
          "blustery": "⚑",
          "cloudy": "☁",
          "day": "〇",
          "foggy": "≡",
          "night": "☾",
          "not_available": "�",
          "rainy": "☔",
          "snowy": "❅",
          "stormy": "☈",
          "sunny": "☼",
          "unknown": "⚠",
          "windy": "☴"
        }
      }
    },
    "powerline.segments.i3wm.scratchpad": {
      "args": {
        "icons": {
          "changed": "○",
          "fresh": "●"
        }
      }
    },
    "powerline.segments.vim.mode": {
      "args": {
        "override": {
          "!": "!SHELL",
          "R": "RPLACE",
          "Rc": "R·COMP",
          "Rv": "V·RPLC",
          "Rx": "R·C-X ",
          "S": "S·LINE",
          "V": "V·LINE",
          "^S": "S·BLCK",
          "^V": "V·BLCK",
          "c": "COMMND",
          "ce": "NRM·EX",
          "cv": "VIM·EX",
          "i": "INSERT",
          "ic": "I·COMP",
          "ix": "I·C-X ",
          "n": "NORMAL",
          "no": "N·OPER",
          "r": "PROMPT",
          "r?": "CNFIRM",
          "rm": "-MORE-",
          "s": "SELECT",
          "v": "VISUAL"
        }
      }
    },
    "powerline.segments.vim.modified_indicator": {
      "args": {
        "text": "+"
      }
    },
    "powerline.segments.vim.readonly_indicator": {
      "args": {
        "text": "⊗"
      }
    },
    "powerline.segments.vim.visual_range": {
      "args": {
        "CTRL_V_text": "↕{rows} ↔{vcols}",
        "V_text": "⇕{rows}",
        "v_text_multiline": "↕{rows}",
        "v_text_oneline": "↔{vcols}"
      }
    },
    "stash": {
      "before": "⌆"
    },
    "time": {
      "before": "⌚ "
    }
  },
  "spaces": 1
}
