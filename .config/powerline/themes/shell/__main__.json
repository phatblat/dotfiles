{
  "segment_data": {
    "cwd": {
      "args": {
        "dir_limit_depth": 3
      }
    },
    "gitstatus": {
      "args": {
        "formats": {
          "ahead": " ↑ {}",
          "behind": " ↓ {}",
          "branch": " {}",
          "changed": " ✚ {}",
          "staged": " ● {}",
          "stashed": " ⚑ {}",
          "tag": " ★ {}",
          "unmerged": " ✖ {}",
          "untracked": " … {}"
        },
        "show_tag": "exact"
      }
    },
    "hostname": {
      "args": {
        "only_if_ssh": true
      }
    },
    "mode": {
      "args": {
        "override": {
          "default": "CMD",
          "insert": "INS",
          "visual": "VIS"
        }
      }
    },
    "xcodeversion": {
      "args": {
        "format": "🛠  {}"
      }
    }
  }
}
