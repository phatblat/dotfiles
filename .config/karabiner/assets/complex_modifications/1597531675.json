{
  "rules": [
    {
      "description": "Press right_alt alone toggles emoji input",
      "manipulators": [
        {
          "from": {
            "key_code": "right_alt",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "right_alt"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar",
              "modifiers": [
                "left_control",
                "left_command"
              ]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ],
  "title": "Emoji-key"
}
