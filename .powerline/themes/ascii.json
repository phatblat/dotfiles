{
  "dividers": {
    "left": {
      "hard": " ",
      "soft": "| "
    },
    "right": {
      "hard": " ",
      "soft": " |"
    }
  },
  "segment_data": {
    "branch": {
      "before": "BR "
    },
    "line_current_symbol": {
      "contents": "LN "
    },
    "powerline.segments.common.battery": {
      "args": {
        "empty_heart": "O",
        "full_heart": "O"
      }
    },
    "powerline.segments.common.cwd": {
      "args": {
        "ellipsis": "..."
      }
    },
    "powerline.segments.common.date": {
      "before": ""
    },
    "powerline.segments.common.email_imap_alert": {
      "before": "MAIL "
    },
    "powerline.segments.common.hostname": {
      "before": "H "
    },
    "powerline.segments.common.network_load": {
      "args": {
        "recv_format": "DL {value:>8}",
        "sent_format": "UL {value:>8}"
      }
    },
    "powerline.segments.common.now_playing": {
      "args": {
        "state_symbols": {
          "fallback": "",
          "pause": "~",
          "play": ">",
          "stop": "X"
        }
      }
    },
    "powerline.segments.common.uptime": {
      "before": "UP  "
    },
    "powerline.segments.common.virtualenv": {
      "before": "(e) "
    },
    "powerline.segments.common.weather": {
      "args": {
        "icons": {
          "blustery": "WIND",
          "cloudy": "CLOUDS",
          "day": "DAY",
          "foggy": "FOG",
          "night": "NIGHT",
          "not_available": "NA",
          "rainy": "RAIN",
          "snowy": "SNOW",
          "stormy": "STORM",
          "sunny": "SUN",
          "unknown": "UKN",
          "windy": "WINDY"
        }
      }
    },
    "powerline.segments.vim.mode": {
      "args": {
        "override": {
          "!": "SHELL",
          "R": "REPLACE",
          "Rv": "V-RPLCE",
          "S": "S-LINE",
          "V": "V-LINE",
          "^S": "S-BLCK",
          "^V": "V-BLCK",
          "c": "COMMND",
          "ce": "EX",
          "cv": "VIM EX",
          "i": "INSERT",
          "n": "NORMAL",
          "no": "N-OPER",
          "r": "PROMPT",
          "r?": "CONFIRM",
          "rm": "MORE",
          "s": "SELECT",
          "v": "VISUAL"
        }
      }
    },
    "powerline.segments.vim.modified_indicator": {
      "args": {
        "text": "+"
      }
    },
    "powerline.segments.vim.readonly_indicator": {
      "args": {
        "text": "RO"
      }
    },
    "powerline.segments.vim.visual_range": {
      "args": {
        "CTRL_V_text": "{rows} x {vcols}",
        "V_text": "L:{rows}",
        "v_text_multiline": "L:{rows}",
        "v_text_oneline": "C:{vcols}"
      }
    }
  },
  "spaces": 1
}
