{
  "default_module": "powerline.segments.vim",
  "segments": {
    "left": [
      {
        "module": "powerline.listers.vim",
        "name": "tabbuflister",
        "segments": [
          {
            "after": " ",
            "exclude_modes": [
              "tab",
              "buf",
              "buf_nc"
            ],
            "name": "tabnr",
            "priority": 5
          },
          {
            "after": " ",
            "exclude_modes": [
              "tab",
              "buf",
              "tab_nc"
            ],
            "name": "bufnr",
            "priority": 5
          },
          {
            "name": "file_directory",
            "priority": 40
          },
          {
            "args": {
              "display_no_file": true
            },
            "name": "file_name",
            "priority": 10
          },
          {
            "exclude_modes": [
              "buf",
              "buf_nc"
            ],
            "name": "tab_modified_indicator",
            "priority": 5
          },
          {
            "exclude_modes": [
              "tab",
              "tab_nc"
            ],
            "name": "modified_indicator",
            "priority": 5
          }
        ],
        "type": "segment_list"
      },
      {
        "draw_hard_divider": false,
        "draw_soft_divider": false,
        "highlight_group": [
          "background"
        ],
        "type": "string",
        "width": "auto"
      }
    ],
    "right": [
      {
        "name": "single_tab"
      }
    ]
  }
}
