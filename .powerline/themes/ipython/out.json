{
  "default_module": "powerline.segments.common",
  "segments": {
    "left": [
      {
        "align": "r",
        "contents": "Out[",
        "draw_soft_divider": false,
        "highlight_group": [
          "prompt"
        ],
        "type": "string",
        "width": "auto"
      },
      {
        "draw_soft_divider": false,
        "module": "powerline.segments.ipython",
        "name": "prompt_count"
      },
      {
        "contents": "]",
        "highlight_group": [
          "prompt"
        ],
        "type": "string"
      }
    ]
  }
}
